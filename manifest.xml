<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xsi:type="MailApp">
<Id>a3f7d2c1-4b8e-4f2a-9c6d-1e0b5a7f3c2d</Id>
<Version>2.1.0.0</Version>
<ProviderName>EmailChainGuard</ProviderName>
<DefaultLocale>it-IT</DefaultLocale>
<DisplayName DefaultValue="EmailChainGuard"/>
<Description DefaultValue="Rileva domain spoofing nelle catene email."/>
<IconUrl DefaultValue="https://pier-coder.github.io/emailchainguard-frontend/icon-32.png"/>
<HighResolutionIconUrl DefaultValue="https://pier-coder.github.io/emailchainguard-frontend/icon-80.png"/>
<SupportUrl DefaultValue="https://pier-coder.github.io/emailchainguard-frontend"/>
<Requirements>
<Sets DefaultMinVersion="1.1">
<Set Name="Mailbox" MinVersion="1.1"/>
</Sets>
</Requirements>
<FormSettings>
<Form xsi:type="ItemRead">
<DesktopSettings>
<SourceLocation DefaultValue="https://pier-coder.github.io/emailchainguard-frontend/taskpane.html"/>
<RequestedHeight>450</RequestedHeight>
</DesktopSettings>
</Form>
</FormSettings>
<Permissions>ReadItem</Permissions>
<Rule xsi:type="RuleCollection" Mode="Or">
<Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
</Rule>
<VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
<Requirements>
<bt:Sets DefaultMinVersion="1.3">
<bt:Set Name="Mailbox" MinVersion="1.3"/>
</bt:Sets>
</Requirements>
<Hosts>
<Host xsi:type="MailHost">
<DesktopFormFactor>
<FunctionFile resid="Taskpane.Url"/>
<ExtensionPoint xsi:type="MessageReadCommandSurface">
<OfficeTab id="TabDefault">
<Group id="msgReadGroup">
<Label resid="GroupLabel"/>
<Control xsi:type="Button" id="msgReadOpenPaneButton">
<Label resid="TaskpaneButton.Label"/>
<Supertip>
<Title resid="TaskpaneButton.Label"/>
<Description resid="TaskpaneButton.Tooltip"/>
</Supertip>
<Icon>
<bt:Image size="16" resid="Icon.16x16"/>
<bt:Image size="32" resid="Icon.32x32"/>
<bt:Image size="80" resid="Icon.80x80"/>
</Icon>
<Action xsi:type="ShowTaskpane">
<SourceLocation resid="Taskpane.Url"/>
</Action>
</Control>
</Group>
</OfficeTab>
</ExtensionPoint>
</DesktopFormFactor>
</Host>
</Hosts>
<Resources>
<bt:Images>
<bt:Image id="Icon.16x16" DefaultValue="https://pier-coder.github.io/emailchainguard-frontend/icon-16.png"/>
<bt:Image id="Icon.32x32" DefaultValue="https://pier-coder.github.io/emailchainguard-frontend/icon-32.png"/>
<bt:Image id="Icon.80x80" DefaultValue="https://pier-coder.github.io/emailchainguard-frontend/icon-80.png"/>
</bt:Images>
<bt:Urls>
<bt:Url id="Taskpane.Url" DefaultValue="https://pier-coder.github.io/emailchainguard-frontend/taskpane.html"/>
</bt:Urls>
<bt:ShortStrings>
<bt:String id="GroupLabel" DefaultValue="Sicurezza"/>
<bt:String id="TaskpaneButton.Label" DefaultValue="EmailChainGuard"/>
</bt:ShortStrings>
<bt:LongStrings>
<bt:String id="TaskpaneButton.Tooltip" DefaultValue="Analizza la catena email per rilevare domain spoofing."/>
</bt:LongStrings>
</Resources>
</VersionOverrides>
</OfficeApp>
